FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install dependencies
RUN pip install --no-cache-dir \
    temporalio \
    ollama \
    httpx \
    fastapi \
    uvicorn \
    pydantic

# Context is root
COPY Homelab /app/Homelab
COPY BettingApp /app/BettingApp

# Set PYTHONPATH
ENV PYTHONPATH="/app/Homelab/scripts:/app/BettingApp/scripts"

# Default command
CMD ["python", "/app/Homelab/scripts/quarterback_worker.py"]
