FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
# We'll install them directly to keep the image simple for now
RUN pip install --no-cache-dir \
    temporalio \
    ollama \
    httpx

# Copy the scripts and the beads manager
# We will mount the .beads directories as volumes
COPY . /app/Homelab
COPY ../BettingApp /app/BettingApp

# Set PYTHONPATH so they can find beads_manager.py
ENV PYTHONPATH="/app/Homelab/scripts:/app/BettingApp/scripts"

# The command will be overridden in docker-compose
CMD ["python", "/app/Homelab/scripts/quarterback_worker.py"]
